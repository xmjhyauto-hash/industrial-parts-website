# =====================================================
# Environment Configuration
# =====================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =====================================================

# Database (SQLite - default for development)
DATABASE_URL="file:./prisma/dev.db"

# =====================================================
# Authentication (REQUIRED - generate secure values)
# =====================================================
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-256-bit-random-secret-here

# =====================================================
# Admin Credentials (REQUIRED - change default password)
# =====================================================
# Default username: admin
# Default password: CHANGE_THIS_PASSWORD
ADMIN_PASSWORD=your-secure-admin-password-here

# =====================================================
# SMTP Configuration (for email notifications)
# =====================================================
# Example for Gmail/Google Workspace:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# Example for AWS SES:
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SMTP_PASS=your-ses-secret
# SMTP_FROM=noreply@yourdomain.com

# =====================================================
# SEO Auto-fetch (optional)
# =====================================================
# BING_API_KEY=your-bing-api-key
# SERP_API_KEY=your-serp-api-key

# =====================================================
# Backup Configuration (optional)
# =====================================================
# Remote backup via SCP:
# BACKUP_SCP_HOST=user@backup-server.com
# BACKUP_SCP_PATH=/path/to/backups

# =====================================================
# Security Notes
# =====================================================
# 1. NEXTAUTH_SECRET must be at least 32 characters
# 2. ADMIN_PASSWORD should be at least 12 characters with mixed case, numbers, symbols
# 3. SMTP credentials should be app-specific passwords, not login passwords
# 4. API keys should be kept secret and rotated periodically
